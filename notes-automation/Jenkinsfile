pipeline {
    agent any
    environment {
        VENV = 'venv'
    }
    stages {
        stage('Create Virtual Environment') {
            steps {
                bat 'py -m venv %VENV%'
            }
        }
        stage('Install Dependencies') {
            steps {
                bat '.\\%VENV%\\Scripts\\python -m pip install --upgrade pip'
                bat '.\\%VENV%\\Scripts\\pip install -r notes-automation\\requirements.txt'
            }
        }
        stage('Start Selenium Grid') {
            steps {
                bat(returnStatus: true, script: 'docker network inspect grid || docker network create grid')
                bat(returnStatus: true, script: 'docker rm -f selenium-hub')
                bat(returnStatus: true, script: 'docker rm -f chrome-node')
                bat '''
                docker run -d ^
                --name selenium-hub ^
                --network grid ^
                -p 4442:4442 ^
                -p 4443:4443 ^
                -p 4444:4444 ^
                selenium/hub:4.21.0
                '''
                bat '''
                docker run -d ^
                --name chrome-node ^
                --network grid ^
                -e SE_EVENT_BUS_HOST=selenium-hub ^
                -e SE_EVENT_BUS_PUBLISH_PORT=4442 ^
                -e SE_EVENT_BUS_SUBSCRIBE_PORT=4443 ^
                -e SE_NODE_MAX_SESSIONS=2 ^
                -e SE_NODE_SESSION_TIMEOUT=300 ^
                selenium/node-chrome:4.21.0
                '''
                script {
                    sleep(time: 20, unit: 'SECONDS')
                }
            }
        }
        stage('Run Tests') {
            steps {
                dir('notes-automation') {
                    script {
                        def result = bat(returnStatus: true, script: '..\\%VENV%\\Scripts\\python -m pytest -v --alluredir=allure-results')
                        if (result != 0) {
                            currentBuild.result = 'UNSTABLE'
                        }
                    }
                }
            }
        }
        stage('Generate Allure Report') {
            steps {
                allure(
                    includeProperties: false,
                    results: [[path: 'notes-automation/allure-results']]
                )
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'notes-automation/allure-results/**', fingerprint: true
            bat(returnStatus: true, script: 'docker stop chrome-node')
            bat(returnStatus: true, script: 'docker stop selenium-hub')
            bat(returnStatus: true, script: 'docker rm -f chrome-node')
            bat(returnStatus: true, script: 'docker rm -f selenium-hub')
        }
        success {
            echo 'Pipeline executed successfully.'
        }
        unstable {
            echo 'Some test cases failed but report was generated.'
        }
        failure {
            echo 'Pipeline encountered critical issues.'
        }
    }
}